// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Nominator {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String
  lastName  String
  Nominee   Nominee[]
}

model Nominee {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  phoneNumber String
  address     String
  placeOfWork String
  occupation  String
  email       String
  description String
  photoURL    String
  slug        String    @unique
  nominator   Nominator @relation(fields: [nominatorId], references: [id])
  nominatorId String
  admin       Admin?    @relation(fields: [adminId], references: [id])
  adminId     String?
  status      String    @default("DENIED")
  deleted     Boolean   @default(false)
}

model MagicToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailTemplate {
  id        String            @id @default(uuid())
  type      String            @unique
  subject   String
  content   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Admin {
  id       String    @id @default(uuid())
  email    String    @unique
  Position String
  Nominee  Nominee[]
}

