model EmailTemplate {
  id        String   @id @default(uuid())
  key       String   @unique  // e.g. "NOMINATION_RECEIVED", "ADMIN_ALERT"
  subject   String
  html      String   // handlebars style: "Hi {{name}} ..."
  text      String?  // optional plaintext
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Admin {
  id       String    @id @default(uuid())
  email    String    @unique
  Position String
  Nominee  Nominee[]
}
