// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Nominator {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String
  lastName  String
  Nominees   Nominee[]
}

model Nominee {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  phoneNumber String
  address     String
  placeOfWork String
  occupation  String
  email       String    @unique
  description String
  aboutme     String?
  photoURL    String?
  slug        String    @unique
  nominator   Nominator @relation(fields: [nominatorId], references: [id])
  nominatorId String
  admin       Admin?    @relation(fields: [adminId], references: [id])
  adminId     String?
  status      String    @default("PENDING")
  deleted     Boolean   @default(false)
}

model MagicToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String    @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

