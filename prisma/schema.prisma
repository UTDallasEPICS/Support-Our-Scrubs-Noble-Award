generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Nominator {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String
  lastName  String
  Nominee   Nominee[]
}

model Nominee {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  phoneNumber String
  address     String
  placeOfWork String
  occupation  String
  email       String
  description String    @db.Text
  photoURL    String
  nominator   Nominator @relation(fields: [nominatorId], references: [id])
  nominatorId String
  admin       Admin?     @relation(fields: [adminId], references: [id])
  adminId     String?
  status      Status    @default(DENIED)
  deleted     Boolean   @default(false)
}

model MagicToken {
  id        Int         @id @default(autoincrement())
  token     String      @unique
  email     String
  expiresAt DateTime
  used      Boolean     @default(false)
  createdAt DateTime    @default(now())
}

model EmailTemplate {
  id        String            @id @default(uuid())
  type      EmailTemplateType @unique
  subject   String
  content   String            @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Admin {
  id       String    @id @default(uuid())
  email    String    @unique
  Position String
  Nominee  Nominee[]
}

enum EmailTemplateType {
  SIGNUP
  NOMINATION
  ACCEPTED
  REJECTED
}

enum Status {
  CREATED
  CONFIRMED
  VERIFIED
  APPROVED
  DENIED
  SENT
}
